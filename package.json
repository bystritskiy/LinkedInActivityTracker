{
  "name": "linkedin-activity-tracker",
  "version": "1.0.11",
  "description": "Local, privacy-first Chrome extension that passively logs your own LinkedIn activity. It never performs actions for you.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "icons": "node scripts/gen-icons.mjs",
    "build:content": "vite build --config vite.content.config.ts",
    "build:worker": "vite build --config vite.worker.config.ts",
    "build:pages": "vite build",
    "build": "npm run clean && npm run icons && npm run build:content && npm run build:worker && npm run build:pages",
    "dev:pages": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
